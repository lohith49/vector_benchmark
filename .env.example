# Copy to .env and fill in.
#
# === LLM (report generator) ===
# Required to run `make report`. Get one from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...

# Model used to write the comparison narrative.
GEMINI_MODEL=gemini-2.5-flash

# === Benchmark scale ===
# How many vectors per dataset to load. Use a small number on a laptop.
#   25000   -> very fast, recall numbers less informative
#   100000  -> good balance for 16 GB RAM (default)
#   full    -> use the entire dataset (1M for SIFT/GloVe, 60k for fashion-mnist)
DATASET_LIMIT=100000

# Number of test queries per dataset. Capped at len(test set).
QUERY_LIMIT=1000

# Comma-separated list. Any subset of: sift-128-euclidean, glove-100-angular, fashion-mnist-784-euclidean
DATASETS=sift-128-euclidean,glove-100-angular,fashion-mnist-784-euclidean

# Comma-separated list. Any subset of: qdrant, weaviate, pgvector
DATABASES=qdrant,weaviate,pgvector

# === Index sweep ===
# HNSW ef_search values to test (comma-separated). Higher = better recall, slower queries.
EF_SEARCH_VALUES=16,32,64,128,256

# HNSW build params (applied to all DBs).
HNSW_M=16
HNSW_EF_CONSTRUCTION=128

# === Connection (set by `make port-forward`; defaults work with kind + port-forward) ===
QDRANT_URL=http://localhost:6333
WEAVIATE_HOST=localhost
WEAVIATE_HTTP_PORT=8080
WEAVIATE_GRPC_PORT=50051
PGVECTOR_DSN=postgresql://bench:bench@localhost:5433/bench
RESULTS_DSN=postgresql://results:results@localhost:5434/results
